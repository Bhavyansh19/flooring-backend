# ── Copy this file to .env ────────────────────────────────────────
# On Render: add these in Service → Environment tab

PORT=5000

# MongoDB Atlas connection string
# Get from https://cloud.mongodb.com → Cluster → Connect → Drivers
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/avenue-surface

# JWT — use a long random string (run: openssl rand -hex 32)
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE=7d

# Stripe — from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# TilesView.ai Store ID — from https://tilesview.ai/tvdesh
TILESVIEW_STORE_ID=REPLACE_ME

# Your Vercel frontend URL (no trailing slash)
# Example: https://avenue-surface.vercel.app
CLIENT_URL=https://your-frontend.vercel.app

NODE_ENV=production
